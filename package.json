{
  "name": "swecham-membership",
  "version": "0.1.0",
  "private": true,
  "description": "SweCham / TSCC Membership System — Thailand-Swedish Chamber of Commerce",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev --turbopack --port 3100",
    "build": "next build --turbopack",
    "vercel-build": "node --import tsx scripts/run-migrations.ts && next build --turbopack",
    "build:analyse": "ANALYZE=true next build --turbopack",
    "start": "next start --port 3100",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:integration:stress": "STRESS_PROFILE=1 STRESS_NUM_RUNS=50 STRESS_WORKERS=10 STRESS_DELAY_MS=200 vitest run --config vitest.integration.config.ts --passWithNoTests tests/integration/events/quota-concurrency.test.ts",
    "test:perf": "tsx scripts/run-perf-tests.ts",
    "perf:f6": "tsx scripts/perf/run-all-f6-perf-benches.ts",
    "perf:f6:strict": "STRICT=true tsx scripts/perf/run-all-f6-perf-benches.ts",
    "verify:f6-f8": "node --env-file=.env.local --import tsx scripts/verify-f6-f8-live-wired.ts",
    "verify:clamav": "node --env-file=.env.local --import tsx scripts/verify-clamav-connectivity.ts",
    "test:e2e": "playwright test --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "check:i18n": "tsx scripts/check-i18n-coverage.ts",
    "check:strict-aria": "tsx scripts/check-i18n-coverage.ts --strict-aria",
    "check:layout": "tsx scripts/check-layout-container-usage.ts",
    "check:fixme": "tsx scripts/check-fixme-budget.ts",
    "check:audit-events": "tsx scripts/check-audit-event-count.ts",
    "check:audit-counts": "tsx scripts/check-cross-module-audit-counts.ts",
    "check:bundle-budgets": "tsx scripts/check-bundle-budgets.ts",
    "check:multi-tenant": "node --env-file=.env.local --import tsx scripts/check-multi-tenant-ready.ts",
    "check:template-seed": "tsx scripts/generate-template-seed-migration.ts --check",
    "check:f71a-schema": "node --env-file=.env.local --import tsx scripts/verify-broadcasts-f71a-schema.ts",
    "check:f9-schema": "node --env-file=.env.local --import tsx scripts/check-f9-schema.ts",
    "check:dates": "tsx scripts/check-dates.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env.local --import tsx scripts/run-migrations.ts",
    "db:migrate:prod": "node --env-file=.env.production --import tsx scripts/run-migrations.ts",
    "db:repair-enums": "node --env-file=.env.local --import tsx scripts/repair-enum-drift.ts",
    "db:verify": "node --env-file=.env.local --import tsx scripts/verify-schema.ts",
    "db:verify:prod": "node --env-file=.env.production --import tsx scripts/verify-schema.ts",
    "db:seed-admin": "node --env-file=.env.local --import tsx scripts/seed-bootstrap-admin.ts",
    "seed:f5-e2e": "node --env-file=.env.local --import tsx scripts/seed-f5-e2e-payment-settings.ts",
    "seed:f5-e2e:reconciliation": "node --env-file=.env.local --import tsx scripts/seed-f5-e2e-reconciliation.ts",
    "db:clear-ratelimit": "node --env-file=.env.local --import tsx scripts/clear-rate-limit.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^3.9.1",
    "@js-joda/core": "^6.0.1",
    "@js-joda/timezone": "^2.25.1",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@react-email/components": "^0.0.33",
    "@react-pdf/renderer": "4.3.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.3.0",
    "@tanstack/react-table": "^8",
    "@tanstack/react-virtual": "^3",
    "@tiptap/core": "3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/pm": "3.22.5",
    "@tiptap/react": "3.22.5",
    "@tiptap/starter-kit": "3.22.5",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "@vercel/blob": "^2.3.3",
    "@vercel/otel": "^1.10.1",
    "clamscan": "^2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "email-validator": "^2",
    "fflate": "^0.8.3",
    "i18n-iso-countries": "^7",
    "isomorphic-dompurify": "2.36.0",
    "lucide-react": "^1.9.0",
    "next": "16.2.3",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "resend": "^4.0.1",
    "sharp": "^0.34.5",
    "sonner": "^1.7.4",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "thai-baht-text": "^2.0.5",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/clamscan": "^2",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.3",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "pdf-parse": "^2.4.5",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@node-rs/argon2",
      "sharp",
      "esbuild"
    ],
    "overrides": {
      "jsdom": "25.0.1",
      "html-encoding-sniffer": "4.0.0",
      "whatwg-url": "14.2.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "jsdom": "*",
        "html-encoding-sniffer": "*",
        "whatwg-url": "*"
      }
    }
  }
}
