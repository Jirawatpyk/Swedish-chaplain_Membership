{
  "name": "swecham-membership",
  "version": "0.1.0",
  "private": true,
  "description": "SweCham / TSCC Membership System — Thailand-Swedish Chamber of Commerce",
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:i18n": "tsx scripts/check-i18n-coverage.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^3.9.1",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@react-email/components": "^0.0.33",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "@vercel/otel": "^1.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "lucide-react": "^0.468.0",
    "next": "16.2.3",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "resend": "^4.0.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@node-rs/argon2",
      "sharp",
      "esbuild"
    ]
  }
}
