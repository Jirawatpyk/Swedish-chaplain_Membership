# -----------------------------------------------------------------------------
# SweCham / TSCC Membership — Environment variables
# -----------------------------------------------------------------------------
# Copy to .env.local and fill in. NEVER commit .env.local or any .env.*.local
# file. Secrets live in Vercel env vars for preview + production.
#
# Schema validation happens at boot via src/lib/env.ts (zod). Missing or
# malformed values will cause the server to refuse to start.
# -----------------------------------------------------------------------------

# --- Database (Neon Postgres, Singapore region) ---
# Pooled connection (runtime)
DATABASE_URL="postgresql://user:pass@host.aws.neon.tech/db?sslmode=require"
# Unpooled connection (drizzle-kit migrations, long-running queries)
DATABASE_URL_UNPOOLED="postgresql://user:pass@host.aws.neon.tech/db?sslmode=require"

# --- Rate limit cache (Upstash Redis via Vercel Marketplace) ---
# Vercel KV integration exports these. @upstash/redis also accepts
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN; we map in env.ts.
KV_REST_API_URL="https://example.upstash.io"
KV_REST_API_TOKEN="your-upstash-rest-token"

# --- Transactional email (Resend) ---
RESEND_API_KEY="re_your_api_key"
RESEND_WEBHOOK_SIGNING_SECRET="whsec_your_webhook_signing_secret"
# From address — MUST match a domain verified in the Resend account
# bound to RESEND_API_KEY. Format: `Display Name <local@domain>` or
# bare `local@domain`. Omit to fall back to the SweCham brand default
# (only works when swecham.se is verified in the Resend account).
RESEND_FROM_EMAIL="SweCham <noreply@example.com>"

# --- Auth cookie signing (HMAC over session cookie integrity) ---
# Generate with: openssl rand -base64 48
AUTH_COOKIE_SIGNING_SECRET="base64-of-48-random-bytes"

# --- Application URLs ---
APP_BASE_URL="http://localhost:3000"
# Comma-separated allow-list for CSRF Origin header check
APP_ALLOWED_ORIGINS="http://localhost:3000"

# --- Operational switches ---
# Read-only mode: when true, middleware returns 503 on every write.
# Used for rollback or scheduled maintenance.
READ_ONLY_MODE="false"

# --- Trust model ---
# Off-Vercel deployments: opt-in to acknowledge that a trusted reverse
# proxy strips and rewrites `x-forwarded-for` upstream of the app.
# When unset (default false), the boot-time
# `assertVercelDeploymentForTrustedXff()` in `src/lib/client-ip.ts`
# emits a console.warn in production if `VERCEL` env var is absent —
# alerting operators that per-IP rate-limit buckets may be spoofable.
# Vercel deployments leave this unset (Vercel's edge handles XFF).
# TRUSTED_REVERSE_PROXY="false"

# --- Bootstrap ---
# Email used by scripts/seed-bootstrap-admin.ts to create the first admin.
# Only used once, then the script refuses to run again.
BOOTSTRAP_ADMIN_EMAIL="admin@swecham.se"

# Member-facing support contact — the `mailto:` target on the portal's
# lapsed-membership + invoice cards. Optional; defaults to info@swecham.se.
# Override per deployment (tenant-config at multi-tenant onboarding).
SUPPORT_EMAIL="info@swecham.se"

# Billing / offline-payment contact — the `mailto:` recipients on the invoice
# "online payment unavailable" card. Comma-separated for multiple recipients
# (e.g. "secretary@swecham.com,finance@swecham.com"). Optional; when unset the
# card falls back to SUPPORT_EMAIL. Separate from BOOTSTRAP_ADMIN_EMAIL, which is
# an admin-account identity, not a contact channel.
BILLING_CONTACT_EMAILS="secretary@swecham.com"

# --- Optional: logging ---
# pino level (fatal, error, warn, info, debug, trace). Defaults to info.
LOG_LEVEL="info"

# --- F2 Multi-tenancy ---
# Single-tenant deployment slug. For SweCham/TSCC: "swecham".
TENANT_SLUG="swecham"
# IANA timezone of the deployed tenant — drives F7 quota-year boundary
# math + reset-date microcopy. Validated at boot against the IANA
# registry via Intl.DateTimeFormat (invalid id refuses to start the app
# rather than silently rendering UTC). Examples:
#   Asia/Bangkok       (SweCham/TSCC default)
#   Europe/Stockholm   (Swedish chamber deployment)
#   UTC                (test / staging fixtures)
# Optional — defaults to Asia/Bangkok if unset.
TENANT_TIMEZONE="Asia/Bangkok"
# Dev-only safety net: loud-fails if a query runs with app.current_tenant unset.
# MUST be false in production.
DEBUG_RLS_STATE="false"

# --- F3 Feature flags ---
# Members & Contacts kill-switch. When false, /api/members/** and /api/portal/**
# return 503 read_only_mode without a code deploy.
FEATURE_F3_MEMBERS="true"

# --- F4 Invoicing (Thai-Tax Receipts) ---
# Vercel Blob (private) read/write token — persists rendered tax-document
# PDFs. Signed URLs are issued per-request with 60s TTL. Get from
# Vercel dashboard → Storage → your Blob store → .env.local tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"

# --- F9 Insights export (SEPARATE private Blob store) ---
# Read/write token for a private-access Vercel Blob store used ONLY for F9
# E-Book / GDPR export artefacts (put({ access: 'private' })). A Blob store is
# public XOR private; the BLOB_READ_WRITE_TOKEN store above is PUBLIC (F4 PDFs +
# F9 logos), so it cannot hold private exports. OPTIONAL — when unset it falls
# back to BLOB_READ_WRITE_TOKEN (dev/test/dark-launch). Ship-day operator (T101a):
# Vercel dashboard → Storage → create a Blob store with PRIVATE access → paste
# its token here BEFORE enabling FEATURE_F9_DASHBOARD.
BLOB_PRIVATE_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"

# Shared secret used by Vercel Cron to authenticate the auto-email
# dispatcher endpoint (/api/cron/auto-email-dispatch). Generate with:
#   openssl rand -hex 32
# Rotate whenever the Cron integration is reinstalled.
CRON_SECRET="32-byte-hex-secret"

# F4 Invoicing kill-switch. When false, /api/invoices/**,
# /api/credit-notes/**, /api/tenant-invoice-settings/**, and
# /api/portal/invoices/** return 503 read_only_mode. Useful for
# emergency write-freeze of financial mutations.
FEATURE_F4_INVOICING="true"

# PG-2 DPA gate — ship VOID-stamped PDF as attachment on cancellation
# emails (FR-036 full). Default false until Resend DPA scope is
# amended to cover binary attachments containing Thai tax-document
# PII (member tax ID + legal name + address). When false the email
# still references the voided doc number + "no longer payable" but
# points at a download link instead of attaching the PDF.
FEATURE_F4_VOID_ATTACHMENT="false"

# --- F6 EventCreate Integration (Phase 7 webhook + Feature 013 CSV) ---
# F6 kill-switch. When false every /api/admin/integrations/eventcreate/**
# + /api/admin/events/** + /api/webhooks/eventcreate/** route returns
# 404 (FR-035 surface-disclosure). Default true — Phase 7 shipped
# webhook-receiver + CSV-import primary path; flip to false if
# EventCreate is decommissioned at tenant level.
FEATURE_F6_EVENTCREATE="true"

# F6.1 sub-flag — toggles the EventCreate-CSV adapter at /api/admin/events/import.
# When false the import endpoint accepts ONLY the generic Phase 7 CSV
# schema (event_external_id/event_name/event_start/...). When true the
# adapter auto-detects EventCreate "Guestlist" exports (29-30 columns,
# embedded multi-line address cells, payment status inferred from
# Notes) and rewrites them through `translateEventCreateRow` BEFORE
# the row enters the use-case. Default true — F6.1 ships behind this
# sub-flag so a per-tenant rollback can drop back to generic-only
# without redeploying. SC-008 rollback trigger is the
# `eventcreate_csv_adapter_mode_detected_total` counter (alerts when
# 5+ admin issues / 7 days).
FEATURE_F6_EVENTCREATE_ADAPTER="true"

# --- F7 Email Broadcast (E-Blast) ---
# Resend Broadcasts API key — SEPARATE Resend product from F1
# transactional. Different suppression list, different sending IPs,
# different reputation pool. Get from Resend dashboard → Broadcasts.
# SECRET — never log, redacted via REDACT_PATHS in src/lib/logger.ts.
RESEND_BROADCASTS_API_KEY="re_xxxxxxxxxxxxxxxx"

# Svix signing secret used to verify Resend Broadcasts webhook events
# at /api/webhooks/resend-broadcasts. ≥32 bytes of entropy. Get from
# Resend dashboard → Webhooks → endpoint config.
# SECRET — never log.
RESEND_BROADCASTS_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxx"

# HMAC secret used to sign one-click unsubscribe tokens served at
# /unsubscribe/[token]. ≥32 bytes of entropy. MUST be DISTINCT from
# AUTH_COOKIE_SIGNING_SECRET (per research.md § 4) — tokens are valid
# forever (FR-030 idempotency / GDPR Art. 21 right-to-object) so
# rotation invalidates outstanding unsubscribe links in members'
# inboxes. Generate with: openssl rand -base64 48
# SECRET — never log.
UNSUBSCRIBE_TOKEN_SECRET="32-byte-base64-or-hex-secret"

# Sender identity for outbound F7 broadcasts. Format either
# `local@domain` or `Display Name <local@domain>`. Domain MUST be
# verified in Resend Broadcasts (separate from F1 transactional
# verification). IANA-reserved TLDs (.example/.invalid/.test) are
# rejected at boot to prevent accidental dispatch from placeholder
# addresses (review C1 — 2026-04-30).
BROADCASTS_FROM_EMAIL="Chamber <broadcasts@swecham.com>"

# F7 kill-switch. When false every /api/broadcasts/** +
# /api/admin/broadcasts/** + /api/cron/broadcasts/** route returns
# 503 feature_disabled. Default false — F7 ships dark; flip to true
# in Vercel env after stakeholder gates close (DPO contact, Resend
# DPA scope, marketing-consent paperwork) + first manual smoke test.
# Mid-flight broadcasts (status submitted/approved) remain visible
# to admins for completion/rejection per FR-002 + Spec § Edge Cases.
FEATURE_F7_BROADCASTS="false"

# --- F7 Optional UX URLs (UX-5 / UX-6) ---
# Public privacy-policy URL surfaced as a link on the member-portal
# marketing-acknowledgement banner. Strengthens GDPR Art. 7
# "demonstrable consent" by letting the member read the policy
# before clicking "I acknowledge". Optional — when unset the banner
# omits the link entirely (no dead anchor). Set ONLY to a URL that
# resolves; do NOT set to a 404.
TENANT_PRIVACY_POLICY_URL="https://swecham.com/privacy"

# Public chamber website URL surfaced as a "Visit chamber website"
# link on the public unsubscribe page (every state — success / already /
# error / invalid). UX-6 nice-to-have. Optional — when unset the link
# is omitted. Set ONLY to a URL that resolves.
TENANT_WEBSITE_URL="https://swecham.com"

# --- F8 Renewal Tracking + Smart Reminders ---
# F8 reuses F1+F4 transactional Resend (RESEND_API_KEY above) for renewal
# reminder emails — NOT F7's Broadcasts API. Renewal reminders are
# TRANSACTIONAL communications (not marketing) per FR-019 + Assumption A5.
# F8 also reuses CRON_SECRET (defined further below) for cron-job.org
# Bearer auth on the 6 F8 cron endpoints.

# F8 kill-switch — full-feature gate. When false every
# /api/cron/renewals/**, /api/admin/renewals/**, and the member portal
# renewal page return 503/404 feature_disabled. Default false — F8
# ships dark; flip to true at MVP-wide chamber go-live (Option C per
# Assumption A12 v3 — when entire MVP F1-F9 + Phase 5B polish complete).
FEATURE_F8_RENEWALS="false"

# F8 granular kill-switch — disables ONLY at-risk widget + at-risk
# recompute cron + score-column reads. Pipeline + reminders +
# tier-upgrade + escalation tasks + member self-service remain fully
# operational. Designed for incident response when at-risk formula
# calibration ships bad signals — restored via env-var revert + redeploy
# in <5 minutes (per FR-052b). Default false — at-risk widget enabled
# when F8 is live.
FEATURE_F8_AT_RISK_DISABLED="false"

# --- COMP-1 Member Erasure (GDPR Art.17 / PDPA §33) ---
# Kill-switch for the US2d member-erasure reconciliation sweep
# (/api/cron/members/reconcile-erasures). When false the cron route returns
# 200 + {skipped:true} so cron-job.org does not retry-storm a pause window.
# The sweep re-drives the idempotent eraseMember for members whose erasure
# committed (members.erased_at set) but whose member_erased completion audit
# never landed (a post-commit cascade failed). Default true — erasure is a
# shipped compliance surface, so the self-healing sweep must run unless an
# operator explicitly pauses it during an incident.
FEATURE_MEMBER_ERASURE_RECONCILE="true"

# HMAC primary signing key for renewal-link tokens (per FR-026 + R1).
# Tokens are HMAC-SHA256 over a JSON payload {v,tid,mid,cid,iat,exp}
# with a 30-day TTL and single-use enforcement via consumed_link_tokens
# table. ≥32 bytes of entropy. MUST be DISTINCT from
# AUTH_COOKIE_SIGNING_SECRET (F1) and UNSUBSCRIBE_TOKEN_SECRET (F7) so
# independent rotation does not invalidate user sessions or marketing
# tokens. Generate with: openssl rand -base64 48
# SECRET — never log.
RENEWAL_LINK_TOKEN_SECRET_PRIMARY="32-byte-base64-or-hex-secret"

# HMAC fallback signing key during dual-key rotation window per R16.
# OPTIONAL — set ONLY during a 30-day rotation window:
#   1. Generate new secret with openssl rand -base64 48.
#   2. Set RENEWAL_LINK_TOKEN_SECRET_FALLBACK = <current PRIMARY value>.
#   3. Set RENEWAL_LINK_TOKEN_SECRET_PRIMARY = <new value>.
#   4. Redeploy. New tokens use PRIMARY; old in-flight tokens (TTL ≤30d)
#      verify against FALLBACK.
#   5. After 30 days, remove FALLBACK.
# Steady state = only PRIMARY set (this var commented out). SECRET — never log.
# RENEWAL_LINK_TOKEN_SECRET_FALLBACK="32-byte-base64-or-hex-secret"

# --- F7.1a Email Broadcast Advanced (Pagination + Image + Templates) ---
# Feature flags ship F7.1a dark until staged flag-flip per
# specs/014-email-broadcast-advance/quickstart.md § 9. Master kill-switch
# must be ON before any per-US flag has effect (see src/lib/env.ts).
FEATURE_F71A_BROADCAST_ADVANCED="false"   # master kill-switch
FEATURE_F71A_US1_PAGINATION="false"       # US1 batch dispatch + retry loop
FEATURE_F71A_US2_IMAGES="false"           # US2 inline image embedding + ClamAV
FEATURE_F71A_US7_TEMPLATES="false"        # US7 multi-template library

# --- ClamAV virus scanner (US2 dependency) ---
# Deployed to Fly.io sin region (clamav-swecham app) per infra/clamav/README.md.
# In dev, run `docker run -d -p 3310:3310 clamav/clamav:stable` and set
# CLAMAV_HOST=localhost. Connectivity probe: pnpm tsx scripts/verify-clamav-connectivity.ts.
CLAMAV_HOST=""                       # e.g. "clamav-swecham.internal" prod / "localhost" dev
CLAMAV_PORT="3310"
CLAMAV_TIMEOUT_MS="300000"           # 5-minute scan timeout per FR-013
# Security boundary in production = Fly.io 6PN private network. clamav-
# swecham.internal is reachable ONLY from chamber-os Vercel functions on
# the same private network. clamscan@2.4 binding has no auth header
# support; an earlier CLAMAV_SHARED_SECRET env var was removed 2026-05-19
# because it was documented as auth but never reached the daemon.

# --- F9 Admin Dashboard + Directory + Timeline + Audit ---
# Kill-switch (default false) — `/admin` keeps the F1 placeholder, F9 surfaces
# short-circuit, and the snapshot/export crons skip until flipped on after the
# Slice-A review gate (research R11). Tables + cron ship dark first.
FEATURE_F9_DASHBOARD="false"
# HMAC secret for single-use, ≤1h private-artefact download tokens
# (/api/internal/exports/[jobId]/download). REQUIRED only when
# FEATURE_F9_DASHBOARD=true (Slice B export proxy). ≥32 bytes; MUST be distinct
# from AUTH_COOKIE_SIGNING_SECRET / UNSUBSCRIBE_TOKEN_SECRET /
# RENEWAL_LINK_TOKEN_SECRET_*. Generate: openssl rand -base64 48. SECRET — never log.
# EXPORT_DOWNLOAD_TOKEN_SECRET="32-byte-base64-or-hex-secret"

# --- F5 Online Payment (Stripe + PromptPay) ---
# Validated by src/lib/env.ts. Use TEST keys locally (sk_test_… / pk_test_…);
# STRIPE_LIVE_MODE must agree with the key prefix (sk_live_ ↔ true) and is only
# allowed true when NODE_ENV=production. Kill-switch ships F5 dark (default false).
# SECRETS — never log STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"
# Pin the Stripe API version (Q5) — must match the dashboard webhook version.
STRIPE_API_VERSION="2025-09-30.clover"
STRIPE_ACCOUNT_ID_SWECHAM="acct_xxxxxxxxxxxx"
STRIPE_LIVE_MODE="false"
FEATURE_F5_ONLINE_PAYMENT="false"
FEATURE_F5_ASYNC_RECEIPT_PDF="false"
